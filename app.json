{
  "expo": {
    "name": "Term Learner",
    "slug": "term-learner",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "termlearner",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#6C63FF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.termlearner.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Term Learner uses your camera to capture vocabulary lists.",
        "NSPhotoLibraryUsageDescription": "Term Learner accesses your photos to upload vocabulary images."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6C63FF"
      },
      "package": "com.termlearner.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#6C63FF",
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Term Learner accesses your photos to upload vocabulary images.",
          "cameraPermission": "Term Learner uses your camera to capture vocabulary lists."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
